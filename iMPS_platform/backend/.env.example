MONGO_URI=mongodb://<user>:<password>@<host>:27017/?authSource=admin&directConnection=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=<your-email>@gmail.com
SMTP_PASS=<gmail-app-password>
SENDER_EMAIL=<your-email>@gmail.com
FRONTEND_BASE_URL=http://localhost:3001
MQTT_BROKER=<broker-ip>
MQTT_PORT=1883

# JWT signing secret — set a strong random value (>=32 chars):
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=

# Shared secret ที่ Maximo ต้องแนบมาใน header X-Maximo-Token เวลายิง webhook เปิดใบงาน PM
# (POST /maximo/pm/open และ POST /maximo/pm-workorder) — ต้องตั้งค่า ไม่งั้น endpoint ตอบ 503
MAXIMO_WEBHOOK_SECRET=
